# This is an example of a .env file for the project. Copy this file to .env and fill in the values.
# Host ports for published services. Change these on shared servers to avoid conflicts.
FRONTEND_HOST_PORT=3200
NESTJS_HOST_PORT=4000
GSEA_HOST_PORT=5000
TOOLUNIVERSE_MCP_HOST_PORT=8000

# Neo4j database credentials
NEO4J_USERNAME=
NEO4J_PASSWORD=

# Redis database credentials
REDIS_PASSWORD=

# Clickhouse database credentials
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
