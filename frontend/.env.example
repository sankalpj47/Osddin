# Backend URL (example when compose uses NESTJS_HOST_PORT=4000)
NEXT_PUBLIC_BACKEND_URL=
# LLM Backend URL (usually same host/port family as backend deployment)
NEXT_PUBLIC_LLM_BACKEND_URL=
# Python Backend URL (example when compose uses GSEA_HOST_PORT=5000)
NEXT_PUBLIC_PYTHON_BACKEND_URL=
# Site URL (for SEO, change this to your site URL)
NEXT_PUBLIC_SITE_URL=https://tbep.missouri.edu
# Google Analytics ID (Optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# Frontend nginx basic auth (leave blank to disable)
FRONTEND_BASIC_AUTH_USERNAME=
FRONTEND_BASIC_AUTH_PASSWORD=
